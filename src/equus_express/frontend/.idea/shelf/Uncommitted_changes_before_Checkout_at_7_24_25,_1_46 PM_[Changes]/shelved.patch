<+>import { NatsSignalsService } from './nats-signals.service';\n\nexport function initializeRouter(natsService: NatsSignalsService) {\n    // Simple client-side routing\n    const routes = {\n        '#/status': () => import('./bioreactor-monitor').then(m => m.setupBioreactorMonitor(natsService, document.querySelector('.page-content') as HTMLElement)),\n        '#/object-model': () => import('./app/object-model').then(m => m.setupObjectModel(natsService, document.querySelector('.page-content') as HTMLElement)),\n        '#/configuration': () => console.log('Configuration route activated'), // Placeholder for now\n        '#/system': () => console.log('System route activated'), // Placeholder for now\n        '#/recipe': () => import('./recipe').then(m => m.initialize()),\n    };\n\n    const routerOutlet = document.querySelector('.page-content');\n    const menuToggleCheckbox = document.getElementById('menu-toggle') as HTMLInputElement;\n    const menuLinks = document.querySelector('.menu-links');\n\n    function navigateTo(path: string) {\n        history.pushState(null, '', path);\n        loadRoute(path);\n        // Close menu if open\n        if (menuToggleCheckbox) {\n            menuToggleCheckbox.checked = false;\n        }\n    }\n\n    function loadRoute(path: string) {\n        if (!routerOutlet) {\n            console.error('Router outlet not found!');\n            return;\n        }\n        routerOutlet.innerHTML = ''; // Clear previous content\n\n        const handler = routes[path as keyof typeof routes];\n        if (handler) {\n            handler().catch(err => console.error(`Failed to load route ${path}:`, err));\n        } else {\n            console.warn(`Route \"${path}\" not found. Redirecting to /status`);\n            navigateTo('/status'); // Default to status page\n        }\n    }\n\n    // Attach click listeners to navigation links\n    if (menuLinks) {\n        menuLinks.querySelectorAll('a').forEach(link => {\n            link.addEventListener('click', (event) => {\n                event.preventDefault();\n                const path = link.getAttribute('routerLink');\n                if (path) {\n                    navigateTo(path);\n                }\n            });\n        });\n    }\n\n    window.onhashchange = () => {\n        const path = window.location.hash;\n        // Call your routing function with the path\n        loadRoute(path);\n    };\n\n    // Handle initial load and back/forward browser navigation\n    window.addEventListener('popstate', () => {\n        // Use window.location.hash for hash-based routing, or window.location.pathname for path-based\n        loadRoute(window.location.hash);\n    });\n\n    // Initial route load (using hash-based routing as per original app.ts)\n    const initialPath = window.location.hash || '#/status';\n    navigateTo(initialPath);\n}\n
