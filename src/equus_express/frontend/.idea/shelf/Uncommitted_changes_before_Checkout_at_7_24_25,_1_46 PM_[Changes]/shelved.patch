<+>.view{\n  display:none;\n}\n.view:target{\n  display:block;\n}\n* {\n  margin: 0;\n  padding: 0;\n  box-sizing: border-box;\n}\n\nbody {\n  font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;\n  background: linear-gradient(135deg, #1a1a2e, #16213e);\n  color: #e0e6ed;\n  height: 100vh;\n  overflow: hidden;\n}\n\n.app-container {\n  display: flex;\n  height: 100vh;\n}\n\n.sidebar {\n  width: 280px;\n  background: rgba(30, 35, 50, 0.95);\n  border-right: 1px solid #3a4553;\n  display: flex;\n  flex-direction: column;\n}\n\n.header {\n  padding: 20px;\n  border-bottom: 1px solid #3a4553;\n  background: rgba(20, 25, 40, 0.8);\n}\n\n.header h1 {\n  color: #64b5f6;\n  font-size: 1.5rem;\n  font-weight: 300;\n}\n\n.status-indicator {\n  display: inline-block;\n  width: 8px;\n  height: 8px;\n  border-radius: 50%;\n  background: #4caf50;\n  margin-left: 10px;\n  animation: pulse 2s infinite;\n}\n\n@keyframes pulse {\n  0% { opacity: 1; }\n  50% { opacity: 0.5; }\n  100% { opacity: 1; }\n}\n\n.nav-section {\n  padding: 20px 0;\n}\n\n.nav-section h3 {\n  padding: 0 20px 10px;\n  color: #90a4ae;\n  font-size: 0.85rem;\n  text-transform: uppercase;\n  letter-spacing: 1px;\n  font-weight: 500;\n}\n\n.nav-item {\n  padding: 12px 20px;\n  cursor: pointer;\n  transition: all 0.2s ease;\n  border-left: 3px solid transparent;\n}\n\n.nav-item:hover {\n  background: rgba(100, 181, 246, 0.1);\n  border-left-color: #64b5f6;\n}\n\n.nav-item.active {\n  background: rgba(100, 181, 246, 0.2);\n  border-left-color: #64b5f6;\n  color: #64b5f6;\n}\n\n.nav-item i {\n  margin-right: 10px;\n  width: 16px;\n}\n\n.main-content {\n  flex: 1;\n  padding: 20px;\n  overflow-y: auto;\n  background: rgba(15, 20, 35, 0.3);\n}\n\n.section {\n  display: none;\n}\n\n.section.active {\n  display: block;\n}\n\n.section-header {\n  margin-bottom: 30px;\n}\n\n.section-title {\n  font-size: 2rem;\n  color: #64b5f6;\n  margin-bottom: 10px;\n  font-weight: 300;\n}\n\n.section-subtitle {\n  color: #90a4ae;\n  font-size: 1rem;\n}\n\n.grid {\n  display: grid;\n  gap: 20px;\n  margin-bottom: 30px;\n}\n\n.grid-2 { grid-template-columns: repeat(2, 1fr); }\n.grid-3 { grid-template-columns: repeat(3, 1fr); }\n.grid-4 { grid-template-columns: repeat(4, 1fr); }\n\n.card {\n  background: rgba(30, 35, 50, 0.8);\n  border-radius: 8px;\n  border: 1px solid #3a4553;\n  padding: 20px;\n  backdrop-filter: blur(10px);\n}\n\n.card-header {\n  display: flex;\n  justify-content: between;\n  align-items: center;\n  margin-bottom: 15px;\n}\n\n.card-title {\n  color: #64b5f6;\n  font-size: 1.1rem;\n  font-weight: 500;\n}\n\n.badge {\n  padding: 4px 8px;\n  border-radius: 4px;\n  font-size: 0.75rem;\n  font-weight: 500;\n  text-transform: uppercase;\n}\n\n.badge-active { background: #4caf50; color: white; }\n.badge-inactive { background: #f44336; color: white; }\n.badge-running { background: #2196f3; color: white; }\n.badge-complete { background: #4caf50; color: white; }\n.badge-fault { background: #f44336; color: white; }\n\n.model-item {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  padding: 15px;\n  background: rgba(40, 45, 60, 0.6);\n  border-radius: 6px;\n  margin-bottom: 10px;\n  border-left: 3px solid #64b5f6;\n}\n\n.stage-item {\n  display: flex;\n  align-items: center;\n  padding: 12px;\n  background: rgba(40, 45, 60, 0.4);\n  border-radius: 6px;\n  margin-bottom: 8px;\n}\n\n.stage-number {\n  width: 30px;\n  height: 30px;\n  border-radius: 50%;\n  background: #64b5f6;\n  color: white;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  margin-right: 15px;\n  font-weight: 500;\n}\n\n.stage-number.complete {\n  background: #4caf50;\n}\n\n.stage-number.current {\n  background: #ff9800;\n  animation: pulse 1.5s infinite;\n}\n\n.stage-number.fault {\n  background: #f44336;\n}\n\n.btn {\n  padding: 8px 16px;\n  border: none;\n  border-radius: 4px;\n  cursor: pointer;\n  font-size: 0.9rem;\n  transition: all 0.2s ease;\n}\n\n.btn-primary {\n  background: #64b5f6;\n  color: white;\n}\n\n.btn-primary:hover {\n  background: #42a5f5;\n}\n\n.btn-secondary {\n  background: #455a64;\n  color: white;\n}\n\n.btn-secondary:hover {\n  background: #546e7a;\n}\n\n.telemetry-grid {\n  display: grid;\n  grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));\n  gap: 15px;\n  margin-bottom: 20px;\n}\n\n.telemetry-card {\n  background: rgba(40, 45, 60, 0.6);\n  border-radius: 6px;\n  padding: 15px;\n  text-align: center;\n}\n\n.telemetry-value {\n  font-size: 1.5rem;\n  font-weight: 500;\n  color: #64b5f6;\n  margin-bottom: 5px;\n}\n\n.telemetry-label {\n  color: #90a4ae;\n  font-size: 0.85rem;\n}\n\n.progress-bar {\n  width: 100%;\n  height: 6px;\n  background: rgba(40, 45, 60, 0.6);\n  border-radius: 3px;\n  overflow: hidden;\n  margin: 10px 0;\n}\n\n.progress-fill {\n  height: 100%;\n  background: linear-gradient(90deg, #64b5f6, #42a5f5);\n  transition: width 0.3s ease;\n}\n\n.bioreactor-grid {\n  display: grid;\n  grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));\n  gap: 20px;\n}\n\n.bioreactor-card {\n  background: rgba(30, 35, 50, 0.9);\n  border: 1px solid #3a4553;\n  border-radius: 8px;\n  overflow: hidden;\n}\n\n.bioreactor-header {\n  padding: 15px 20px;\n  background: rgba(20, 25, 40, 0.8);\n  border-bottom: 1px solid #3a4553;\n}\n\n.bioreactor-body {\n  padding: 20px;\n}\n\n.port-mapping {\n  display: grid;\n  grid-template-columns: 1fr 1fr;\n  gap: 10px;\n  margin-top: 15px;\n}\n\n.port-item {\n  display: flex;\n  justify-content: space-between;\n  padding: 8px;\n  background: rgba(40, 45, 60, 0.4);\n  border-radius: 4px;\n  font-size: 0.85rem;\n}
